{
  "info": {
    "name": "Learning Progress API - LMS",
    "description": "Collection để test các API theo dõi tiến độ học tập chi tiết (Video, Slide, Document) bằng Heartbeat.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0.1 Đăng Nhập (Học Sinh)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"student.cntt01@lms.local\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Gọi API này để lấy JWT Token của Học Sinh. Dùng để chạy các API 1, 2, 3, 4."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(jsonData.accessToken) {",
              "    pm.collectionVariables.set(\"token\", jsonData.accessToken);",
              "    console.log(\"Token auto-saved to collection variables!\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ]
    },
    {
      "name": "0.2 Đăng Nhập (Giảng Viên)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"teacher.csharp.a@lms.local\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Gọi API này để lấy JWT Token của Giảng Viên. Dùng để chạy API 5."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(jsonData.accessToken) {",
              "    pm.collectionVariables.set(\"token\", jsonData.accessToken);",
              "    console.log(\"Token auto-saved to collection variables!\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ]
    },
    {
      "name": "0.3 Đăng Nhập (Admin/Giáo Vụ)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"giaovu.hcm@lms.local\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Gọi API này để lấy JWT Token của Admin/Giáo vụ. Dùng để chạy API 5."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(jsonData.accessToken) {",
              "    pm.collectionVariables.set(\"token\", jsonData.accessToken);",
              "    console.log(\"Token auto-saved to collection variables!\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ]
    },
    {
      "name": "1. Khởi tạo phiên học (Start Session)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"maNoiDung\": {{contentId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/learning-progress/sessions/start",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "learning-progress",
            "sessions",
            "start"
          ]
        },
        "description": "Gọi khi học sinh bắt đầu mở 1 video hoặc slide. Sẽ trả về `sessionToken` dùng cho các heartbeat."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(jsonData.sessionToken) {",
              "    pm.collectionVariables.set(\"sessionToken\", jsonData.sessionToken);",
              "    console.log(\"Session Token auto-saved!\");",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Gửi Heartbeat",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sessionToken\": \"{{sessionToken}}\",\n  \"soThuTuNhipTim\": 1,\n  \"viTriVideoGiay\": 30,\n  \"phanTramCuon\": 15.5\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/learning-progress/heartbeat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "learning-progress",
            "heartbeat"
          ]
        },
        "description": "Gửi định kỳ (mặc định 30s 1 lần). Cần tăng `soThuTuNhipTim` lên 1 sau mỗi lần gửi. Gửi kèm `viTriVideoGiay` nếu là video, hoặc `phanTramCuon` nếu là slide/pdf."
      }
    },
    {
      "name": "3. Kết thúc phiên (End Session)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/learning-progress/sessions/{{sessionToken}}/end",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "learning-progress",
            "sessions",
            "{{sessionToken}}",
            "end"
          ]
        },
        "description": "Gọi khi học sinh đóng tab, bấm quay lại hoặc chuyển sang nội dung khác."
      }
    },
    {
      "name": "4. Lấy chi tiết tiến độ 1 Nội dung",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/learning-progress/contents/{{contentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "learning-progress",
            "contents",
            "{{contentId}}"
          ]
        },
        "description": "Học sinh xem tiến độ, trạng thái (đang học, hoàn thành) và % hoàn thành của 1 bài học."
      }
    },
    {
      "name": "5. Báo cáo tiến độ Lớp (Cho GV/Admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/learning-progress/classes/{{classId}}/students",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "learning-progress",
            "classes",
            "{{classId}}",
            "students"
          ]
        },
        "description": "Giáo viên chủ nhiệm lớp hành chính hoặc Admin lấy danh sách tiến độ các môn học/bài học của tất cả học sinh trong lớp."
      }
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5097",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN",
      "type": "string"
    },
    {
      "key": "sessionToken",
      "value": "00000000-0000-0000-0000-000000000000",
      "type": "string"
    },
    {
      "key": "contentId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "classId",
      "value": "1",
      "type": "string"
    }
  ]
}
