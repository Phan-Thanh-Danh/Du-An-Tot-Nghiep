{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=LMS;Integrated Security=True;TrustServerCertificate=True"
  },

  "JwtSettings": {
    "Secret": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "LMS.Backend",
    "Audience": "LMS.Client",
    "ExpiresInMinutes": 60
  },

  "AllowedHosts": "*"
}
